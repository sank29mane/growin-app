new file mode 100644
index 0000000..a822143
--- /dev/null
+++ b/backend/utils/mlx_loader.py
@@ -0,0 +1,31 @@
+"""
+Centralized utility for safe MLX imports.
+Handles non-Apple Silicon CI environments by providing mock modules when MLX is unavailable.
+"""
+
+from typing import Any
+
+try:
+    import mlx.core as mx
+    import mlx.nn as nn
+    HAS_MLX = True
+    MLX_AVAILABLE = True
+except ImportError:
+    mx = None
+    
+    class DummyModule:
+        def __init__(self, *args, **kwargs): pass
+        def __call__(self, *args, **kwargs): pass
+        
+    class _MockNN:
+        Module = DummyModule
+        
+        @staticmethod
+        def Linear(*args, **kwargs): return lambda x: x
+        
+        @staticmethod
+        def TransformerEncoder(*args, **kwargs): return lambda x: x
+        
+    nn = _MockNN
+    HAS_MLX = False
+    MLX_AVAILABLE = False
