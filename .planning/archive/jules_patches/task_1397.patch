+import asyncio
+import time
+from backend.agents.goal_planner_agent import GoalPlannerAgent
+from backend.data_engine import AlpacaClient
+from unittest.mock import AsyncMock, patch
+
+async def run():
+    agent = GoalPlannerAgent()
+    tickers = [f"AAPL" for _ in range(1)]
+    
+    with patch('backend.data_engine.AlpacaClient.get_batch_bars', new_callable=AsyncMock) as mock_get_batch_bars:
+        mock_get_batch_bars.return_value = {t: {"bars": [{"close": 100.0, "c": 100.0} for _ in range(252)]} for t in tickers}
+        
+        start = time.time()
+        result = await agent._fetch_real_data(tickers)
+        end = time.time()
+        
+        print(f"Time taken: {end - start:.4f} seconds")
+        print(f"Number of API calls: {mock_get_batch_bars.call_count}")
+
+asyncio.run(run())

